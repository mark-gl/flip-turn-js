{
  "name": "flip-turn-js",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot demo/index.html demo/single.html",
    "start": "bun demo/index.html demo/single.html",
    "turnjs-dev": "bun --hot demo/turnjs/index.html demo/turnjs/single.html",
    "turnjs-start": "bun demo/turnjs/index.html demo/turnjs/single.html",
    "lint": "bunx tsc --noEmit && bunx eslint . && bunx prettier --check .",
    "test-e2e": "bunx playwright test tests/flip-turn.spec.ts",
    "update-reference-snapshots": "bunx playwright test tests/flip-turn.spec.ts --update-snapshots"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "typescript-eslint": "^8.58.2"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "prettier": {
    "semi": true,
    "printWidth": 80,
    "tabWidth": 2,
    "singleQuote": false,
    "trailingComma": "es5"
  }
}
